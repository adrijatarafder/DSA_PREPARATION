def main():

    N = 5

    # Outer loop runs N times, once for each row
    for i in range(1, N + 1):
        # Inner loop prints 'i - 1' spaces
        for _ in range(i - 1):
            print("  ", end="")

        # Inner loop prints 'N - i + 1' stars
        for _ in range(N - i + 1):
            print("*", end="")


        print()

if __name__ == "__main__":
    main()
