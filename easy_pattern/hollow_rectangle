def print_rectangle(rows, columns):

    for i in range(1, rows + 1):
        for j in range(1, columns + 1):

            # Print star at boundary positions
            if i == 1 or i == rows or j == 1 or j == columns:
                print("*", end="")
            else:
                print(" ", end="")

        # Move to the next line
        print()
